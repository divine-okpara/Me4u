rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - bio: string (optional)
    //   - coins: number (required)
    //   - role: string (required, ['user', 'admin'])
    //   - isVerified: bool (optional)
    //   - privacySettings: map (optional)
    //   - lastActive: timestamp (optional)
    //
    // Collection: swipes
    // Document ID: {swipeId}
    // Fields:
    //   - fromUid: string (required)
    //   - toUid: string (required)
    //   - type: string (required, ['like', 'dislike', 'superlike'])
    //   - timestamp: timestamp (required)
    //
    // Collection: matches
    // Document ID: {matchId}
    // Fields:
    //   - uids: list (required)
    //   - timestamp: timestamp (required)
    //
    // Collection: stories
    // Document ID: {storyId}
    // Fields:
    //   - uid: string (required)
    //   - mediaUrl: string (required)
    //   - type: string (required, ['image', 'video'])
    //   - vibe: string (optional)
    //   - timestamp: timestamp (required)
    //   - expiresAt: timestamp (required)
    //
    // Collection: gifts
    // Document ID: {giftId}
    // Fields:
    //   - fromUid: string (required)
    //   - toUid: string (required)
    //   - amount: number (required)
    //   - message: string (optional)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "divineokpara01@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'displayName', 'coins', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.coins is int && data.coins >= 0 &&
             data.role in ['user', 'admin'] &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('privacySettings' in data) || data.privacySettings is map);
    }

    function isValidSwipe(data) {
      return hasRequiredFields(['fromUid', 'toUid', 'type', 'timestamp']) &&
             data.fromUid == request.auth.uid &&
             data.type in ['like', 'dislike', 'superlike'] &&
             data.timestamp is timestamp;
    }

    function isValidStory(data) {
      return hasRequiredFields(['uid', 'mediaUrl', 'type', 'timestamp', 'expiresAt']) &&
             data.uid == request.auth.uid &&
             data.type in ['image', 'video'] &&
             data.timestamp is timestamp &&
             data.expiresAt is timestamp;
    }

    function isValidSuperComment(data) {
      return hasRequiredFields(['fromUid', 'targetUid', 'targetId', 'targetType', 'text', 'amount', 'timestamp']) &&
             data.fromUid == request.auth.uid &&
             data.targetType in ['profile', 'story'] &&
             data.text is string && data.text.size() > 0 && data.text.size() < 200 &&
             data.amount == 50 &&
             data.timestamp is timestamp;
    }

    function isValidTransaction(data) {
      return hasRequiredFields(['uid', 'type', 'amount', 'description', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.type in ['purchase', 'spend'] &&
             data.amount is int &&
             data.timestamp is timestamp;
    }

    function isMatch(uid1, uid2) {
      let matchId = uid1 < uid2 ? uid1 + '_' + uid2 : uid2 + '_' + uid1;
      return exists(/databases/$(database)/documents/matches/$(matchId));
    }

    function isBlocked(targetUid, byUid) {
      let settings = get(/databases/$(database)/documents/users/$(byUid)).data.privacySettings;
      return 'blockedUsers' in settings && targetUid in settings.blockedUsers;
    }

    function canSeeStories(storyOwnerUid) {
      let settings = get(/databases/$(database)/documents/users/$(storyOwnerUid)).data.privacySettings;
      let visibility = 'showStories' in settings ? settings.showStories : 'everyone';
      return visibility == 'everyone' || 
             (visibility == 'matches' && isMatch(request.auth.uid, storyOwnerUid)) ||
             isOwner(storyOwnerUid);
    }

    function canChatWith(recipientUid) {
      let settings = get(/databases/$(database)/documents/users/$(recipientUid)).data.privacySettings;
      let allowFrom = 'allowChatFrom' in settings ? settings.allowChatFrom : 'everyone';
      let sender = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      
      return !isBlocked(request.auth.uid, recipientUid) && (
        allowFrom == 'everyone' ||
        (allowFrom == 'verified_only' && 'isVerified' in sender && sender.isVerified == true) ||
        (allowFrom == 'matches_only' && isMatch(request.auth.uid, recipientUid))
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coins']) && request.resource.data.coins > resource.data.coins) ||
        isAdmin()
      );
    }

    match /swipes/{swipeId} {
      allow read: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidSwipe(request.resource.data) && !isBlocked(request.auth.uid, request.resource.data.toUid);
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.uids || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.uids;
    }

    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidStory(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /gifts/{giftId} {
      allow read: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.fromUid == request.auth.uid && !isBlocked(request.auth.uid, request.resource.data.toUid);
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.reporterUid == request.auth.uid;
    }

    match /super_comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSuperComment(request.resource.data) && !isBlocked(request.auth.uid, request.resource.data.targetUid);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      // Transactions should only be created by the server for security, but we'll allow client-side creation for 'spend' actions if needed.
      // Actually, for real money, it's better if only server can create 'purchase' transactions.
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && request.resource.data.type == 'spend';
    }

    match /matches/{matchId}/messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.uids || isAdmin());
      allow create: if isAuthenticated() && 
                    (request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.uids) && 
                    request.resource.data.senderUid == request.auth.uid &&
                    canChatWith(request.resource.data.recipientUid);
    }
  }
}
